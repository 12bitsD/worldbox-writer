# Copy this file to `tests/.env.test` and fill in real credentials.
# `tests/.env.test` is gitignored. NEVER commit a real key.
#
# Lines starting with `#` are ignored. Format is `KEY=value` (no quotes
# required for simple values; quotes are stripped if present).
#
# The conftest.py session fixture loads any `LLM_*` keys from this file
# and sets them in os.environ before any test runs. Existing env
# values are NOT overridden.

LLM_API_KEY=sk-your-real-key-here
LLM_BASE_URL=https://api.kimi.com/coding/
LLM_PROVIDER=kimi
LLM_MODEL=kimi-k2.5
